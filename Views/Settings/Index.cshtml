@model TwitchKickDownloader.Models.ViewModels.SettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<h2><i class="bi bi-gear-fill"></i> Settings</h2>

@if (string.IsNullOrWhiteSpace(Model.KickClientId) || string.IsNullOrWhiteSpace(Model.KickClientSecret))
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <strong>Kick credentials required.</strong>
        Kick Client ID &amp; Secret are needed to use the official Kick API for monitoring and downloads.
        Get them from <a href="https://dev.kick.com" target="_blank" class="alert-link">dev.kick.com</a>.
    </div>
}

<div class="row">
    <div class="col-md-7">
        <form asp-action="Index" method="post">
            @Html.AntiForgeryToken()

            <div class="card mb-3">
                <div class="card-header">Twitch API Credentials <small class="text-muted">(optional)</small></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="ClientId" class="form-label"></label>
                        <input asp-for="ClientId" class="form-control font-monospace" />
                        <div class="form-text">Get these from <a href="https://dev.twitch.tv/console" target="_blank">dev.twitch.tv/console</a></div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ClientSecret" class="form-label"></label>
                        <input asp-for="ClientSecret" class="form-control font-monospace" type="password" />
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Kick API Credentials <small class="text-muted">(required for Kick)</small></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="KickClientId" class="form-label"></label>
                        <input asp-for="KickClientId" class="form-control font-monospace" />
                        <div class="form-text">Get these from <a href="https://dev.kick.com" target="_blank">dev.kick.com</a></div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="KickClientSecret" class="form-label"></label>
                        <input asp-for="KickClientSecret" class="form-control font-monospace" type="password" />
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Storage</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="StoragePath" class="form-label"></label>
                        <input asp-for="StoragePath" class="form-control font-monospace" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="FfmpegPath" class="form-label"></label>
                        <input asp-for="FfmpegPath" class="form-control font-monospace" />
                        <div class="form-text">Leave empty to auto-download FFmpeg on first run.</div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Monitoring</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="LivePollIntervalSeconds" class="form-label"></label>
                            <input asp-for="LivePollIntervalSeconds" class="form-control" type="number" min="10" max="3600" />
                            <span asp-validation-for="LivePollIntervalSeconds" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="VodPollIntervalSeconds" class="form-label"></label>
                            <input asp-for="VodPollIntervalSeconds" class="form-control" type="number" min="30" max="7200" />
                            <span asp-validation-for="VodPollIntervalSeconds" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="MaxConcurrentDownloads" class="form-label"></label>
                            <input asp-for="MaxConcurrentDownloads" class="form-control" type="number" min="1" max="10" />
                            <span asp-validation-for="MaxConcurrentDownloads" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Settings</button>
        </form>
    </div>
</div>
