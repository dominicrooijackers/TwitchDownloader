@model List<TwitchDownloader.Models.Entities.DownloadJob>
@{
    ViewData["Title"] = "Download Jobs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-list-task"></i> Download Jobs</h2>
</div>

<div id="jobs-container">
@foreach (var job in Model)
{
    <div class="card mb-2 job-card" id="job-@job.Id" data-status="@job.Status.ToString().ToLower()">
        <div class="card-body py-2 px-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <strong>@job.StreamerLogin</strong>
                    <span class="badge @GetBadgeClass(job.Status) ms-1">@job.Status</span>
                    <span class="badge bg-secondary ms-1">@(job.JobType switch {
                        TwitchDownloader.Models.Entities.JobType.LiveStream => "Live",
                        TwitchDownloader.Models.Entities.JobType.VodOnDemand => "VOD (Manual)",
                        TwitchDownloader.Models.Entities.JobType.VodAuto => "VOD (Auto)",
                        _ => job.JobType.ToString()
                    })</span>
                    <small class="text-muted ms-2">@job.Title</small>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <small class="text-muted" title="@job.StartedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC">
                        <i class="bi bi-clock"></i> Started @job.StartedAt.ToString("MMM d, HH:mm")
                    </small>
                    @if (job.BytesDownloaded > 0)
                    {
                        <small class="text-muted bytes-display">
                            <i class="bi bi-download"></i> <span class="bytes-value">@FormatBytes(job.BytesDownloaded)</span>
                        </small>
                    }
                    <button class="btn btn-sm btn-outline-secondary" onclick="toggleLogs(@job.Id, this)">
                        <i class="bi bi-terminal"></i> Logs
                    </button>
                    @if (job.Status == TwitchDownloader.Models.Entities.JobStatus.Queued ||
                         job.Status == TwitchDownloader.Models.Entities.JobStatus.Downloading ||
                         job.Status == TwitchDownloader.Models.Entities.JobStatus.Muxing)
                    {
                        <button class="btn btn-sm btn-outline-danger cancel-btn" onclick="cancelJob(@job.Id)">
                            <i class="bi bi-x-circle"></i> Cancel
                        </button>
                    }
                </div>
            </div>
            @{
                var isActive = job.Status == TwitchDownloader.Models.Entities.JobStatus.Queued ||
                               job.Status == TwitchDownloader.Models.Entities.JobStatus.Downloading ||
                               job.Status == TwitchDownloader.Models.Entities.JobStatus.Muxing;
            }
            @if (job.Status == TwitchDownloader.Models.Entities.JobStatus.Muxing)
            {
                <div class="progress mt-1" style="height:6px">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-info"
                         role="progressbar" style="width:100%" title="Muxing — FFmpeg is converting to MP4"></div>
                </div>
            }
            else if (isActive && job.ProgressPct.HasValue)
            {
                <div class="progress mt-1" style="height:6px">
                    <div class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar" style="width:@(job.ProgressPct.Value.ToString("F0"))%" title="Downloading — @(job.ProgressPct.Value.ToString("F0"))%"></div>
                </div>
            }
            else if (isActive && job.Status == TwitchDownloader.Models.Entities.JobStatus.Downloading)
            {
                <div class="progress mt-1" style="height:6px">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                         role="progressbar" style="width:100%" title="Downloading segments..."></div>
                </div>
            }
            @if (job.ErrorMessage is not null)
            {
                <small class="text-danger">@job.ErrorMessage</small>
            }
            <div id="job-logs-@job.Id" class="job-logs mt-2" style="display:none"></div>
        </div>
    </div>
}
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-1"></i>
        <p>No download jobs yet. Add streamers and enable monitoring to get started.</p>
    </div>
}

@functions {
    string GetBadgeClass(TwitchDownloader.Models.Entities.JobStatus status) => status switch
    {
        TwitchDownloader.Models.Entities.JobStatus.Queued => "bg-secondary",
        TwitchDownloader.Models.Entities.JobStatus.Downloading => "bg-primary",
        TwitchDownloader.Models.Entities.JobStatus.Muxing => "bg-info text-dark",
        TwitchDownloader.Models.Entities.JobStatus.Completed => "bg-success",
        TwitchDownloader.Models.Entities.JobStatus.Failed => "bg-danger",
        TwitchDownloader.Models.Entities.JobStatus.Cancelled => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / 1024.0 / 1024.0:F1} MB";
        return $"{bytes / 1024.0 / 1024.0 / 1024.0:F2} GB";
    }
}

@section Scripts {
<script>
const levelColors = { Information: 'text-primary', Warning: 'text-warning', Error: 'text-danger', Critical: 'text-danger' };
const levelBadges = { Information: 'text-bg-primary', Warning: 'text-bg-warning', Error: 'text-bg-danger', Critical: 'text-bg-danger' };

function toggleLogs(jobId, btn) {
    const panel = document.getElementById('job-logs-' + jobId);
    if (panel.style.display !== 'none') {
        panel.style.display = 'none';
        btn.classList.remove('active');
        return;
    }
    btn.classList.add('active');
    panel.style.display = '';
    panel.innerHTML = '<div class="text-muted small"><span class="spinner-border spinner-border-sm"></span> Loading logs...</div>';
    fetch('/Logs/ForJob/' + jobId)
        .then(r => r.json())
        .then(logs => renderJobLogs(panel, logs));
}

function renderJobLogs(panel, logs) {
    if (!logs.length) {
        panel.innerHTML = '<div class="text-muted small fst-italic">No logs captured for this job.</div>';
        return;
    }
    const rows = logs.map(e => {
        const badge = levelBadges[e.level] ?? 'text-bg-secondary';
        const ts = new Date(e.timestamp).toLocaleTimeString('en-GB', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
        const shortCat = e.category.split('.').pop();
        const exc = e.exception ? `<div class="text-danger" style="white-space:pre-wrap;font-size:0.7rem">${escapeHtml(e.exception)}</div>` : '';
        return `<div class="d-flex gap-2 py-1 border-bottom" style="font-size:0.78rem">
            <span class="text-muted text-nowrap">${ts}</span>
            <span class="badge ${badge}" style="min-width:70px">${e.level}</span>
            <span class="text-muted text-nowrap">${escapeHtml(shortCat)}</span>
            <span class="font-monospace flex-fill" style="word-break:break-all">${escapeHtml(e.message)}${exc}</span>
        </div>`;
    }).join('');
    panel.innerHTML = `<div class="border rounded p-2 bg-body-secondary" style="max-height:300px;overflow-y:auto">${rows}</div>`;
}

function escapeHtml(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
}
