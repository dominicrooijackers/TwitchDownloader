@model TwitchDownloader.Models.ViewModels.StreamerListViewModel
@{
    ViewData["Title"] = "Streamers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people-fill"></i> Streamers</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Add Streamer</a>
</div>

<ul class="nav nav-tabs mb-3" id="streamerTabs">
    <li class="nav-item">
        <a class="nav-link active" data-bs-toggle="tab" href="#live-tab">
            <i class="bi bi-broadcast"></i> Live Monitoring (@Model.LiveStreamers.Count)
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#vod-tab">
            <i class="bi bi-collection-play"></i> VOD Monitoring (@Model.VodStreamers.Count)
        </a>
    </li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade show active" id="live-tab">
        @if (!Model.LiveStreamers.Any())
        {
            <div class="text-muted py-3">No streamers with live monitoring enabled.</div>
        }
        else
        {
            <table class="table table-hover">
                <thead><tr>
                    <th>Streamer</th><th>Platform</th><th>Quality</th><th>Actions</th>
                </tr></thead>
                <tbody>
                @foreach (var s in Model.LiveStreamers)
                {
                    <tr>
                        <td><strong>@s.DisplayName</strong> <small class="text-muted">@s.TwitchLogin</small></td>
                        <td>@if (s.Platform == TwitchDownloader.Models.Entities.Platform.Kick)
                            { <span class="badge text-bg-success">Kick</span> }
                            else
                            { <span class="badge text-bg-primary">Twitch</span> }</td>
                        <td><span class="badge bg-secondary">@s.PreferredQuality</span></td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Remove @s.DisplayName?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>

    <div class="tab-pane fade" id="vod-tab">
        @if (!Model.VodStreamers.Any())
        {
            <div class="text-muted py-3">No streamers with VOD monitoring enabled.</div>
        }
        else
        {
            <table class="table table-hover">
                <thead><tr>
                    <th>Streamer</th><th>Platform</th><th>Quality</th><th>Auto-Download</th><th>Actions</th>
                </tr></thead>
                <tbody>
                @foreach (var s in Model.VodStreamers)
                {
                    <tr>
                        <td><strong>@s.DisplayName</strong> <small class="text-muted">@s.TwitchLogin</small></td>
                        <td>@if (s.Platform == TwitchDownloader.Models.Entities.Platform.Kick)
                            { <span class="badge text-bg-success">Kick</span> }
                            else
                            { <span class="badge text-bg-primary">Twitch</span> }</td>
                        <td><span class="badge bg-secondary">@s.PreferredQuality</span></td>
                        <td>
                            @if (s.AutoDownloadVods)
                            { <span class="badge text-bg-success">Auto</span> }
                            else
                            { <span class="badge text-bg-secondary">Manual</span> }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="openVodBrowser('@s.TwitchLogin', '@s.PreferredQuality', '@s.Platform')">
                                <i class="bi bi-collection-play"></i> Browse VODs
                            </button>
                            <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Remove @s.DisplayName?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- VOD Browser Modal -->
<div class="modal fade" id="vodModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-collection-play"></i> VOD Browser — <span id="vodModalLogin"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="vodList" class="row g-3">
                    <div class="col-12 text-center"><div class="spinner-border"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="vodOverwriteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill text-warning"></i> File Already Exists</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>A recording for <strong id="overwriteVodTitle"></strong> already exists on disk.</p>
                <p class="text-muted mb-0">Do you want to overwrite it or cancel?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="overwriteConfirmBtn"><i class="bi bi-trash"></i> Overwrite</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let currentLogin = '';
let currentQuality = 'best';
let currentPlatform = 'Twitch';
const vodModal = new bootstrap.Modal(document.getElementById('vodModal'));
const vodOverwriteModal = new bootstrap.Modal(document.getElementById('vodOverwriteModal'));

function openVodBrowser(login, quality, platform) {
    currentLogin = login;
    currentQuality = quality;
    currentPlatform = platform || 'Twitch';
    document.getElementById('vodModalLogin').textContent = login + (currentPlatform === 'Kick' ? ' (Kick)' : '');
    document.getElementById('vodList').innerHTML = '<div class="col-12 text-center"><div class="spinner-border"></div></div>';
    vodModal.show();
    fetch(`/Streamers/GetVods?login=${encodeURIComponent(login)}&platform=${encodeURIComponent(currentPlatform)}`)
        .then(r => r.json())
        .then(vods => renderVods(vods))
        .catch(e => { document.getElementById('vodList').innerHTML = '<div class="col-12 text-danger">Failed to load VODs.</div>'; });
}

function renderVods(vods) {
    if (!vods.length) {
        document.getElementById('vodList').innerHTML = '<div class="col-12 text-muted">No VODs found.</div>';
        return;
    }
    document.getElementById('vodList').innerHTML = vods.map(v => `
        <div class="col-md-4 col-lg-3">
            <div class="card h-100">
                <img src="${v.thumbnailUrl.replace('%{width}','320').replace('%{height}','180')}" class="card-img-top" onerror="this.style.display='none'">
                <div class="card-body p-2">
                    <p class="card-text small fw-bold mb-1">${escapeHtml(v.title)}</p>
                    <p class="card-text text-muted" style="font-size:0.75rem">${v.duration} &middot; ${new Date(v.createdAt).toLocaleDateString()}</p>
                    <button class="btn btn-sm btn-primary w-100 vod-download-btn" data-vod-id="${v.id}" data-vod-title="${escapeHtml(v.title)}">
                        <i class="bi bi-download"></i> Download
                    </button>
                </div>
            </div>
        </div>
    `).join('');
}

document.getElementById('vodList').addEventListener('click', function(e) {
    const btn = e.target.closest('.vod-download-btn');
    if (btn) checkAndDownload(btn.dataset.vodId, btn.dataset.vodTitle);
});

function checkAndDownload(vodId, title) {
    fetch(`/Streamers/VodExists?login=${encodeURIComponent(currentLogin)}&vodId=${encodeURIComponent(vodId)}&title=${encodeURIComponent(title)}`)
        .then(r => r.json())
        .then(data => {
            if (data.exists) {
                document.getElementById('overwriteVodTitle').textContent = title;
                document.getElementById('overwriteConfirmBtn').onclick = function () {
                    vodOverwriteModal.hide();
                    submitDownload(vodId, title);
                };
                vodOverwriteModal.show();
            } else {
                submitDownload(vodId, title);
            }
        });
}

function submitDownload(vodId, title) {
    const form = document.createElement('form');
    form.method = 'post';
    form.action = '/Streamers/DownloadVod';
    const fields = { '__RequestVerificationToken': getAntiForgeryToken(), login: currentLogin, vodId, title, quality: currentQuality, platform: currentPlatform };
    for (const [name, value] of Object.entries(fields)) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = name;
        input.value = value;
        form.appendChild(input);
    }
    document.body.appendChild(form);
    form.submit();
}

function escapeHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function getAntiForgeryToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
}
</script>
}
